+        return_activations: bool | None,
+    ) -> ErrorResponse | None:
+        if return_explanations:
+            if not self.model_config.extract_activation_layers:
+                return self.create_error_response(
+                    "`return_explanations` requires the server to be started "
+                    "with `--extract-activation-layers`.",
+                    param="return_explanations",
+                )
+            if not self.activation_processor_socket:
+                return self.create_error_response(
+                    "`return_explanations` requires the server to be started "
+                    "with `--activation-processor-socket`.",
+                    param="return_explanations",
+                )
+
+        if return_activations and not self.model_config.extract_activation_layers:
+            return self.create_error_response(
+                "`return_activations` requires the server to be started with "
