+                param="return_activations",
+            )
+
+        return None
+
+    async def _create_activation_explanations(
+        self,
+        *,
+        request_id: str,
+        model_name: str,
+        choice_index: int,
+        activations: Mapping[int, Any] | None,
+    ) -> dict[int, Any]:
+        serialized = serialize_activations(activations)
+        if not serialized:
+            raise ValueError(
+                "No activations were captured for `return_explanations`."
+            )
+        if not self.activation_processor_socket:
+            raise ValueError("Activation processor socket is not configured.")
+
+        transport = httpx.AsyncHTTPTransport(
+            uds=self.activation_processor_socket,
+        )
+        timeout = httpx.Timeout(self.activation_processor_timeout_seconds)
+        async with httpx.AsyncClient(
+            transport=transport,
+            timeout=timeout,
+        ) as client:
+            response = await client.post(
+                "http://activation-processor/v1/activation_explanations",
+                json={
+                    "request_id": request_id,
