+            if layer_index < 0:
+                raise ValueError(
+                    "extract_activation_layers must only contain non-negative "
+                    "integers."
+                )
+            if layer_index not in seen_layers:
+                layers.append(layer_index)
+                seen_layers.add(layer_index)
+
